float readBatteryVoltage() {
#if ENABLE_BATTERY
  static float filteredVoltage = 0.0f;
  float rawVoltage = (analogReadMilliVolts(VBAT_PIN) / 1000.0f) * DIVIDER_RATIO;
  if (filteredVoltage == 0.0f) {
    filteredVoltage = rawVoltage;
  }
  filteredVoltage = (filteredVoltage * 0.90f) + (rawVoltage * 0.10f);
  return filteredVoltage;
#else
  return 0.0f;
#endif
}

void checkAndRecoverI2C() {
  if (Wire.getError() != 0) {
    Serial.println("OSTRZEŻENIE: Wykryto błąd I2C! Próba restartu magistrali...");
    Wire.end();
    delay(5);
    Wire.begin(I2C_SDA_PIN, I2C_SCL_PIN);
    Wire.setTimeOut(10);
    pca.begin();
    pca.setPWMFreq(SERVO_FREQUENCY);
  }
}

void configureMPU6050DLPF() {
#if ENABLE_IMU
  Wire.beginTransmission(0x68); // Adres I2C MPU6050
  Wire.write(0x1A);             // Rejestr CONFIG
  Wire.write(0x03);             // Setting 3 = DLPF ~42Hz
  Wire.endTransmission();
  Serial.println("MPU6050: Sprzętowy DLPF ustawiony na 42Hz.");
#endif
}


uint16_t getWifiRssiForMSP() {
  if (WiFi.status() != WL_CONNECTED) return 0;
  int dbm = WiFi.RSSI();
  int quality = constrain(map(dbm, -90, -30, 0, 100), 0, 100);
  return map(quality, 0, 100, 0, 1023);
}

void calibratePCA9685() {
  Serial.println("\n--- Rozpoczynam autokalibrację PCA9685 ---");
  pinMode(CALIBRATION_PIN, INPUT);

  uint32_t currentFreq = 25000000;
  pca.setOscillatorFrequency(currentFreq);
  pca.setPWMFreq(SERVO_FREQUENCY);

  int targetUs = 1500;
  int error = 1000;
  int attempts = 0;

  pca.setPWM(CALIBRATION_CH, 0, 307);
  delay(100);

  while (abs(error) > 3 && attempts < 15) {
    unsigned long measuredUs = pulseIn(CALIBRATION_PIN, HIGH, 100000);

    if (measuredUs == 0) {
      Serial.println("BŁĄD: Brak sygnału na pinie kalibracyjnym! Sprawdź połączenie.");
      break;
    }

    error = targetUs - (int)measuredUs;
    Serial.printf("Próba %d: Zmierzono %lu us | Błąd: %d us\n", attempts + 1, measuredUs, error);

    if (abs(error) <= 3) {
      Serial.println("Kalibracja ZAKOŃCZONA SUKCESEM!");
      break;
    }

    currentFreq = (uint32_t)(currentFreq * ((float)targetUs / (float)measuredUs));
    pca.setOscillatorFrequency(currentFreq);
    pca.setPWMFreq(SERVO_FREQUENCY);
    pca.setPWM(CALIBRATION_CH, 0, 307);
    delay(50); 
    attempts++;
  }
  Serial.printf("Ostateczna częstotliwość oscylatora: %lu Hz\n\n", currentFreq);
}

void triggerFailsafe() {
  for (int i = 0; i < NUM_CHANNELS; i++) {
    uint16_t pwm_ticks = (NEUTRAL_PULSE * 4096UL) / (1000000UL / SERVO_FREQUENCY);
    pca.setPWM(i, 0, pwm_ticks);
  }
  failsafeActive = true;
}

void i2c_scan() {
  byte error, address;
  int nDevices = 0;
  Serial.println("Skanowanie magistrali I2C...");
  for(address = 1; address < 127; address++) {
    Wire.beginTransmission(address);
    error = Wire.endTransmission();
    if (error == 0) {
      Serial.printf("Znaleziono urządzenie I2C pod adresem 0x%02X\n", address);
      nDevices++;
    }
  }
  if (nDevices == 0) Serial.println("Nie znaleziono żadnych urządzeń I2C!\n");
}

#if ENABLE_CAMERA
void videoTask(void *pvParameters) {
  while (true) {
    WiFiClient client = videoServer.available();
    if (client) {
      client.setNoDelay(true);
      client.println("HTTP/1.1 200 OK");
      client.println("Content-Type: multipart/x-mixed-replace; boundary=frame");
