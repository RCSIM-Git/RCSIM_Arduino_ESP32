bool initIMU() {
#if (ACTIVE_IMU == IMU_TYPE_MPU6050)
  if (mpu.begin() == 0) {
    mpu.calcOffsets();
    configureMPU6050DLPF(); // Ustawienie sprzętowego filtra DLPF
    return true;
  }
  return false;

#elif (ACTIVE_IMU == IMU_TYPE_MPU9250)
  if (mpu.init()) {
    mpu.autoOffsets();
    mpu.setSampleRate(MPU9250_SR_200Hz);
    mpu.setDlpfer(MPU9250_DLPF_6); // DLPF ~42Hz
    return true;
  }
  return false;

#elif (ACTIVE_IMU == IMU_TYPE_BNO08X)
  if (bno08x.begin_I2C()) {
    bno08x.enableReport(SH2_ARVR_STABILIZED_ROTATION_VECTOR, 20000); // 50Hz (20000us)
    bno08x.enableReport(SH2_ACCELEROMETER, 20000);
    bno08x.enableReport(SH2_GYROSCOPE_CALIBRATED, 20000);
    return true;
  }
  return false;

#elif (ACTIVE_IMU == IMU_TYPE_BMX160)
  if (bmx160.begin()) {
    return true;
  }
  return false;
#endif
}

// --- 3. UNIWERSALNE POBIERANIE DANYCH (UPDATE) ---
void updateIMU() {
#if (ACTIVE_IMU == IMU_TYPE_MPU6050)
  mpu.update();
  imu_roll  = mpu.getAngleX();
  imu_pitch = mpu.getAngleY();
  imu_yaw   = mpu.getAngleZ();
  imu_ax    = mpu.getAccX();
  imu_ay    = mpu.getAccY();
  imu_az    = mpu.getAccZ();
  imu_gx    = mpu.getGyroX();
  imu_gy    = mpu.getGyroY();
  imu_gz    = mpu.getGyroZ();

#elif (ACTIVE_IMU == IMU_TYPE_MPU9250)
  xyzFloat gAcc = mpu.getGValues();
  xyzFloat angles = mpu.getAngles();
  xyzFloat gyro = mpu.getGyroValues();
  imu_roll  = angles.x;
  imu_pitch = angles.y;
  imu_yaw   = angles.z;
  imu_ax    = gAcc.x;
  imu_ay    = gAcc.y;
  imu_az    = gAcc.z;
  imu_gx    = gyro.x;
  imu_gy    = gyro.y;
  imu_gz    = gyro.z;

#elif (ACTIVE_IMU == IMU_TYPE_BNO08X)
  if (bno08x.getSensorEvent(&sensorValue)) {
    if (sensorValue.sensorId == SH2_ARVR_STABILIZED_ROTATION_VECTOR) {
      float qr = sensorValue.un.arvrStabilizedRotationVector.real;
      float qi = sensorValue.un.arvrStabilizedRotationVector.i;
      float qj = sensorValue.un.arvrStabilizedRotationVector.j;
      float qk = sensorValue.un.arvrStabilizedRotationVector.k;

      imu_roll  = atan2(2.0f * (qr * qi + qj * qk), 1.0f - 2.0f * (qi * qi + qj * qj)) * RAD_TO_DEG;
      imu_pitch = asin(constrain(2.0f * (qr * qj - qk * qi), -1.0f, 1.0f)) * RAD_TO_DEG;
      imu_yaw   = atan2(2.0f * (qr * qk + qi * qj), 1.0f - 2.0f * (qj * qj + qk * qk)) * RAD_TO_DEG;
    }
    if (sensorValue.sensorId == SH2_ACCELEROMETER) {
      imu_ax = sensorValue.un.accelerometer.x / 9.81f;
      imu_ay = sensorValue.un.accelerometer.y / 9.81f;
      imu_az = sensorValue.un.accelerometer.z / 9.81f;
    }
    if (sensorValue.sensorId == SH2_GYROSCOPE_CALIBRATED) {
      imu_gx = sensorValue.un.gyroscope.x * RAD_TO_DEG; // rad/s na deg/s
      imu_gy = sensorValue.un.gyroscope.y * RAD_TO_DEG;
      imu_gz = sensorValue.un.gyroscope.z * RAD_TO_DEG;
    }
  }

#elif (ACTIVE_IMU == IMU_TYPE_BMX160)
  sBmx160SensorData_t Omagn, Ogyro, Oacc;
  bmx160.getAllData(&Omagn, &Ogyro, &Oacc);
  imu_ax = Oacc.x / 9.81f;
  imu_ay = Oacc.y / 9.81f;
  imu_az = Oacc.z / 9.81f;
  imu_gx = Ogyro.x * RAD_TO_DEG;
  imu_gy = Ogyro.y * RAD_TO_DEG;
  imu_gz = Ogyro.z * RAD_TO_DEG;
  imu_roll  = atan2(imu_ay, imu_az) * RAD_TO_DEG;
  imu_pitch = atan2(-imu_ax, sqrt(imu_ay * imu_ay + imu_az * imu_az)) * RAD_TO_DEG;
#endif
}

#endif

