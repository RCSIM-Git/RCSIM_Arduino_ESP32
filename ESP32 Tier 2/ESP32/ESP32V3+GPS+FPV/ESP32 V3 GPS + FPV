// =================================================================================
// FUNKCJE POMOCNICZE MSP (WALKSNAIL OSD)
// =================================================================================
#if ENABLE_WALKSNAIL_OSD
void sendMSP(uint8_t cmd, uint8_t *payload, uint8_t size) {
  uint8_t checksum = 0;
  VtxSerial.write('$');
  VtxSerial.write('M');
  VtxSerial.write('<');
  VtxSerial.write(size);
  checksum ^= size;
  VtxSerial.write(cmd);
  checksum ^= cmd;
  
  for (uint8_t i = 0; i < size; i++) {
    VtxSerial.write(payload[i]);
    checksum ^= payload[i];
  }
  VtxSerial.write(checksum);
}

void sendWalksnailAttitude(float roll, float pitch, float yaw) {
  int16_t r = (int16_t)(roll * 10.0f);
  int16_t p = (int16_t)(pitch * 10.0f);
  int16_t y = (int16_t)yaw;

  uint8_t payload[6];
  payload[0] = r & 0xFF; payload[1] = (r >> 8) & 0xFF;
  payload[2] = p & 0xFF; payload[3] = (p >> 8) & 0xFF;
  payload[4] = y & 0xFF; payload[5] = (y >> 8) & 0xFF;

  sendMSP(108, payload, 6); // Cmd 108 = MSP_ATTITUDE
}

void sendWalksnailAnalog(float voltage, uint16_t rssi) {
  uint8_t vbat = (uint8_t)(voltage * 10.0f);
  uint16_t powerMeter = 0;
  int16_t amperage = 0;

  uint8_t payload[7];
  payload[0] = vbat;
  payload[1] = powerMeter & 0xFF; payload[2] = (powerMeter >> 8) & 0xFF;
  payload[3] = rssi & 0xFF;       payload[4] = (rssi >> 8) & 0xFF;
  payload[5] = amperage & 0xFF;   payload[6] = (amperage >> 8) & 0xFF;

  sendMSP(110, payload, 7); // Cmd 110 = MSP_ANALOG
}

void sendWalksnailStatus(bool isArmed) {
  uint16_t cycleTime = 1000;
  uint16_t i2cErrorCounter = 0;
  uint16_t sensor = 0x07; 
  uint32_t flightModeFlags = isArmed ? 0x00000001 : 0x00000000; 

  uint8_t payload[11];
  payload[0] = cycleTime & 0xFF;       payload[1] = (cycleTime >> 8) & 0xFF;
  payload[2] = i2cErrorCounter & 0xFF; payload[3] = (i2cErrorCounter >> 8) & 0xFF;
  payload[4] = sensor & 0xFF;          payload[5] = (sensor >> 8) & 0xFF;
  payload[6] = flightModeFlags & 0xFF; payload[7] = (flightModeFlags >> 8) & 0xFF;
  payload[8] = (flightModeFlags >> 16) & 0xFF; payload[9] = (flightModeFlags >> 24) & 0xFF;
  payload[10] = 0;

  sendMSP(101, payload, 11); // Cmd 101 = MSP_STATUS
}

void sendWalksnailName(const char* name) {
  uint8_t len = strlen(name);
  if (len > 16) len = 16;
  sendMSP(10, (uint8_t*)name, len); // Cmd 10 = MSP_NAME
}

#if ENABLE_GPS
void sendWalksnailGPS() {
  uint8_t fix = (gps.satellites.value() >= 4) ? 2 : 0;
  uint8_t numSat = gps.satellites.value();
  int32_t lat = (int32_t)(gps.location.lat() * 10000000.0);
  int32_t lon = (int32_t)(gps.location.lng() * 10000000.0);
  uint16_t alt = (uint16_t)gps.altitude.meters();
  uint16_t speed = (uint16_t)(gps.speed.mps() * 100.0f);  
  uint16_t course = (uint16_t)(gps.course.deg() * 10.0f); 

  uint8_t payload[16];
  payload[0]  = fix; payload[1] = numSat;
  payload[2]  = lat & 0xFF; payload[3]  = (lat >> 8) & 0xFF;
  payload[4]  = (lat >> 16) & 0xFF; payload[5]  = (lat >> 24) & 0xFF;
  payload[6]  = lon & 0xFF; payload[7]  = (lon >> 8) & 0xFF;
  payload[8]  = (lon >> 16) & 0xFF; payload[9]  = (lon >> 24) & 0xFF;
  payload[10] = alt & 0xFF; payload[11] = (alt >> 8) & 0xFF;
  payload[12] = speed & 0xFF; payload[13] = (speed >> 8) & 0xFF;
  payload[14] = course & 0xFF; payload[15] = (course >> 8) & 0xFF;

  sendMSP(106, payload, 16); // Cmd 106 = MSP_RAW_GPS
}
#endif
